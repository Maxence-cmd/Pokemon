<Application x:Class="Pokemon.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Pokemon"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Style ProgressBar PV (couleur change via trigger) -->
        <Style x:Key="HpBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid SnapsToDevicePixels="True">

                            <!-- Fond -->
                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"/>

                            <!-- Barre dynamique -->
                            <Border x:Name="Indicator"
                            Background="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left"/>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- 🔥 largeur basée sur VALUE -->
                            <Trigger Property="Value" Value="0">
                                <Setter TargetName="Indicator" Property="Width" Value="0"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style ProgressBar EXP (bleu fixe) -->
        <Style x:Key="ExpBarStyle" BasedOn="{StaticResource HpBarStyle}"
       TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#50A0F0"/>
        </Style>
    </Application.Resources>
</Application>

<Window x:Class="Pokemon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pokemon"
        Title="Pokédex"
        Width="1100"
        Height="900"
        WindowStartupLocation="CenterScreen">

    <!-- Fond dégradé bleu/rose/violet -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#93C5FD" Offset="0"/>
            <GradientStop Color="#C4B5FD" Offset="0.5"/>
            <GradientStop Color="#F9A8D4" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">

            <!-- Titre -->
            <TextBlock Text="Pokédex"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Recherchez un Pokémon par nom ou numéro"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,30"/>

            <!-- Recherche -->
            <Border Background="White"
                    CornerRadius="16"
                    Padding="16"
                    Margin="0,0,0,30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="4"
                                      Opacity="0.15"/>
                </Border.Effect>
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- TEXTBOX -->
                    <Grid Grid.Column="0">

                        <TextBox x:Name="NumPokeRecherche"
                 Height="44"
                 Margin="0,0,12,0"
                 FontSize="16"
                 VerticalContentAlignment="Center"
                 TextChanged="NumPokeRecherche_TextChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 Panel.ZIndex="1"/>

                        <!-- POPUP SUGGESTIONS -->
                        <Popup x:Name="SuggestionPopup"
               PlacementTarget="{Binding ElementName=NumPokeRecherche}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">

                            <Border Background="White"
                    CornerRadius="8"
                    Padding="5"
                    Width="{Binding ActualWidth, ElementName=NumPokeRecherche}"
                    BorderBrush="#DDD"
                    BorderThickness="1">

                                <ListBox x:Name="SuggestionList"
                         MaxHeight="200"
                         SelectionChanged="SuggestionList_SelectionChanged"/>

                            </Border>

                        </Popup>

                    </Grid>



                    <!-- Bouton arrondi avec hover -->
                    <Button x:Name="BttRecherche" Grid.Column="1"
                            Content="🔍 Rechercher"
                            Padding="20,10"
                            FontWeight="SemiBold"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Background="#6366F1" Click="BttRecherche_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#4F46E5"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3730A3"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#A5B4FC"/>
                                        <Setter Property="Foreground" Value="#E5E7EB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Carte Pokémon -->
            <Border Background="White"
                    CornerRadius="24"
                    Padding="0"
                    Margin="0,0,0,40">
                <StackPanel>

                    <!-- Header dégradé -->
                    <Border Height="120" CornerRadius="24,24,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#60A5FA" Offset="0"/>
                                <GradientStop Color="#EC4899" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Name="NomPokemon" Text="Charmeleon"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Name="NumPokemon" Text="#005"
                                       Foreground="White"
                                       Opacity="0.8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Grid HorizontalAlignment="Center" Margin="0,10">

                        <!-- BOUTON ATTAQUE POKEMON -->
                        <Button x:Name="AttaqueBtn"
            Content="⚔ Attaque"
            Width="140"
            Height="40"
            HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="0,12,-350,0"
            Foreground="White"
            FontWeight="Bold"
            Cursor="Hand"
            Background="#EF4444"
            Click="Combat_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="border"
                        Background="#EF4444"
                        CornerRadius="20"
                        Padding="10">

                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15"
                                          Color="Red"
                                          ShadowDepth="0"
                                          Opacity="0.6"/>
                                        </Border.Effect>

                                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                Property="Background"
                                Value="#DC2626"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                Property="Background"
                                Value="#991B1B"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>

                            </Button.Template>

                        </Button>

                        <!-- Image centrée -->
                        <Image Name="ImgPokemon"
           Source="https://raw.githubusercontent.com/Yarkis01/TyraDex/images/sprites/1/regular.png"
           Width="200"
           Height="200"
           HorizontalAlignment="Center"
           VerticalAlignment="Top"
           Margin="0,42,0,0">

                            <Image.Effect>
                                <DropShadowEffect BlurRadius="15"
                              ShadowDepth="4"
                              Opacity="0.2"/>
                            </Image.Effect>

                        </Image>

                        <!-- Boutons en haut à droite -->
                        <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="12">

                            <CheckBox Name="ShinyCheckBox"
                  ToolTip="Afficher version Shiny"
                  Margin="0,0,8,0"
                  Checked="ShinyCheckBox_Checked"
                  Unchecked="ShinyCheckBox_Unchecked">
                                <TextBlock Text="✨"/>
                            </CheckBox>

                            <CheckBox Name="GmaxCheckBox"
                  ToolTip="Afficher version Gigamax"
                  Margin="0,0,8,0"
                  Checked="GmaxCheckBox_Checked"
                  Unchecked="GmaxCheckBox_Unchecked">
                                <TextBlock Text="🔥"/>
                            </CheckBox>

                            <CheckBox Name="MegaCheckBox"
                  ToolTip="Afficher Méga-Évolution"
                  Checked="MegaCheckBox_Checked"
                  Unchecked="MegaCheckBox_Unchecked">
                                <TextBlock Text="💠"/>
                            </CheckBox>

                        </StackPanel>

                    </Grid>
                    <!-- Contenu -->
                    <StackPanel Margin="20,0,20,24">

                        <!-- Type -->
                        <TextBlock Text="TYPE : "
                                   FontWeight="Bold"
                                   Foreground="#666"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">

                            <Border Padding="4"
                                    CornerRadius="50"
                                    Margin="0,0,8,24">
                                <Image Name="Type1Pokemon" Source="https://raw.githubusercontent.com/Yarkis01/TyraDex/images/types/plante.png"
                                     Width="40"
                                     Height="40"
                                     Stretch="Uniform"/>
                            </Border>

                            <Border Padding="4"
                                    CornerRadius="12"
                                    Margin="0,0,0,24">
                                <Image Name="Type2Pokemon" 
                                         Width="40"
                                         Height="40"
                                         Stretch="Uniform"/>
                            </Border>

                        </StackPanel>

                        <!-- Stats -->
                        <TextBlock Text="STATISTIQUES DE BASE : "
                                   FontWeight="Bold"
                                   Foreground="#666"
                                   Margin="0,0,0,12"/>

                        <!-- PV -->
                        <StackPanel Margin="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="PV" Text="PV"/>
                                <TextBlock Name="PVNumPokemon"  Text="50" Grid.Column="1" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Name="PVPokemon" Height="8" Value="50" Maximum="255" Background="#E5E7EB" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>

                        <!-- Attaque -->
                        <StackPanel Margin="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="Att" Text="Attaque"/>
                                <TextBlock Name="AttNumPokemon" Text="50" Grid.Column="1" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Name="AttPokemon" Height="8" Value="50" Maximum="255" Background="#E5E7EB" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>

                        <!-- Défense -->
                        <StackPanel Margin="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="Def" Text="Défense"/>
                                <TextBlock Name="DefNumPokemon" Text="50" Grid.Column="1" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Name="DefPokemon" Height="8" Value="50" Maximum="255" Background="#E5E7EB" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>

                        <!-- Attaque Spéciale -->
                        <StackPanel Margin="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="AttSpe" Text="Atq. Spé"/>
                                <TextBlock Name="AttSpeNumPokemon" Text="50" Grid.Column="1" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Name="AttSpePokemon" Height="8" Value="50" Maximum="255" Background="#E5E7EB" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>

                        <!-- Défense Spéciale -->
                        <StackPanel Margin="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="DefSpe" Text="Déf. Spé"/>
                                <TextBlock Name="DefSpeNumPokemon" Text="50" Grid.Column="1" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Name="DefSpePokemon" Height="8" Value="50" Maximum="255" Background="#E5E7EB" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>

                        <!-- Vitesse -->
                        <StackPanel Margin="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="Vit" Text="Vitesse"/>
                                <TextBlock Name="VitNumPokemon" Text="80" Grid.Column="1" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Name="VitPokemon"  Height="8" Value="50" Maximum="255" Background="#E5E7EB" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>
                        <!-- Catégorie et Génération -->
                        <TextBlock FontWeight="Bold" Foreground="#666" Text="AUTRES INFORMATIONS :" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="Catégorie : " FontWeight="SemiBold"/>
                            <TextBlock Name="CategoriePokemon" Text="Pokémon Graine"/>
                            <TextBlock Text="Génération : " FontWeight="SemiBold" Margin="20,0,0,0"/>
                            <TextBlock Name="GenerationPokemon" Text="1"/>
                        </StackPanel>

                        <!-- Noms dans les différentes langues -->
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="Nom EN : " FontWeight="SemiBold"/>
                            <TextBlock Name="NomEN" Text="Venusaur"/>
                            <TextBlock Text="Nom JP : " FontWeight="SemiBold" Margin="20,0,0,0"/>
                            <TextBlock Name="NomJP" Text="フシギバナ"/>
                        </StackPanel>

                        <!-- Talents -->
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="Talents : " FontWeight="SemiBold"/>
                            <ItemsControl Name="TalentsPokemon" >
                                <!-- Les talents seront ajoutés depuis le code-behind -->
                            </ItemsControl>
                        </StackPanel>

                        <!-- Taille et Poids -->
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="Taille : " FontWeight="SemiBold"/>
                            <TextBlock Name="TaillePokemon" Text="2,0 m"/>
                            <TextBlock Text="Poids : " FontWeight="SemiBold" Margin="20,0,0,0"/>
                            <TextBlock Name="PoidsPokemon" Text="100,0 kg"/>
                        </StackPanel>

                    </StackPanel>
                    <!-- Chaîne d'évolution stylée -->
                    <TextBlock Text="CHAÎNE D'ÉVOLUTION : "
                           Margin="20,0,0,0"    
           FontWeight="Bold"
           Foreground="#666"
           />

                    <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                        <!-- BASE 1 -->
                        <StackPanel Margin="10" HorizontalAlignment="Center">
                            <TextBlock Name="Base1Nom"
                   Text="Nom 1"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
                            <Image Name="Base1Img"
                                   Source="https://raw.githubusercontent.com/Yarkis01/TyraDex/images/sprites/1/regular.png"
               Width="110"
               Height="110"/>
                            <TextBlock Name="Base1Id"
                   Text="#000"
                   HorizontalAlignment="Center"
                   Opacity="0.7"/>
                        </StackPanel>

                        <!-- FLECHE + CONDITION 1 -->
                        <StackPanel x:Name="FlecheCond1" Margin="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                            <!-- Condition au-dessus -->
                            <TextBlock Name="Cond1Txt"
                   Text="Niv. ??"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4"/>

                            <!-- Flèche -->
                            <TextBlock Text="➡"
                   FontSize="28"
                   HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- BASE 2 -->
                        <StackPanel Margin="10" HorizontalAlignment="Center">
                            <TextBlock Name="Base2Nom"
                   Text="Nom 2"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
                            <Image Name="Base2Img"
                                    Source="https://raw.githubusercontent.com/Yarkis01/TyraDex/images/sprites/2/regular.png"
               Width="110"
               Height="110"/>
                            <TextBlock Name="Base2Id"
                                      
                   Text="#000"
                   HorizontalAlignment="Center"
                   Opacity="0.7"/>
                        </StackPanel>

                        <!-- FLECHE + CONDITION 2 -->
                        <StackPanel Margin="10"
                                    x:Name="FlecheCond2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                            <TextBlock Name="Cond2Txt"
                   Text="Niv. ??"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4"/>

                            <TextBlock Text="➡"
                   FontSize="28"
                   HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- BASE 3 -->
                        <StackPanel Margin="10" HorizontalAlignment="Center">
                            <TextBlock Name="Base3Nom"
                   Text="Nom 3"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
                            <Image Name="Base3Img"
                                   Source="https://raw.githubusercontent.com/Yarkis01/TyraDex/images/sprites/3/regular.png"
               Width="110"
               Height="110"/>
                            <TextBlock Name="Base3Id"
                   Text="#000"
                   HorizontalAlignment="Center"
                   Opacity="0.7"/>
                            
                        </StackPanel>
                        <StackPanel x:Name="aide" HorizontalAlignment="Center" Margin="0,20,0,0">

                            <Button x:Name="AideBtn"
     Content="❓ Aide"
     Width="180"
     Height="45"
     FontWeight="Bold"
     Background="#10B981"
     Foreground="White"
     BorderThickness="0" Click="AideBtn_Click"/>
                        </StackPanel>


                    </StackPanel>
                    
                </StackPanel>
            </Border>
            
        </StackPanel>

       
    </ScrollViewer>
    
</Window>

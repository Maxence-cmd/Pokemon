<Window x:Class="Pokemon.Views.chasse"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="chasse"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Focusable="True"
        WindowState="Maximized"
        ResizeMode="NoResize">
    <Grid Background="Black">
        <Grid x:Name="TeamScreen" Background="#A8D0D0" Visibility="Collapsed">

            <Canvas Width="900" Height="550">

                <!-- ===== SLOT 1 ===== -->
                <Border x:Name="Slot1" Canvas.Left="20" Canvas.Top="20"
                Width="300" Height="100"
                Background="#F8F8D8"
                BorderBrush="#282828" BorderThickness="4"
                CornerRadius="8" MouseDown="Slot_Click">
                    <Grid Margin="8">
                        <Image x:Name="Img1" Width="70" Height="70"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <StackPanel Margin="90,0,0,0">
                            <TextBlock x:Name="Name1" Text="N/A" FontSize="16" FontWeight="Bold"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="HP" Margin="0,0,6,0"/>
                                <Grid Width="180" Height="10" Background="#3A3A3A">
                                    <Border x:Name="HpBar1" Background="#58D050"
                                    HorizontalAlignment="Left" Width="180"/>
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="Hp1" Text="0/0" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== SLOT 2 ===== -->
                <Border x:Name="Slot2" Canvas.Left="350" Canvas.Top="50"
                Width="300" Height="100"
                Background="#F8F8D8"
                BorderBrush="#282828" BorderThickness="4"
                CornerRadius="8" MouseDown="Slot_Click">
                    <Grid Margin="8">
                        <Image x:Name="Img2" Width="70" Height="70"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <StackPanel Margin="90,0,0,0">
                            <TextBlock x:Name="Name2" Text="N/A" FontSize="16"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="HP" Margin="0,0,6,0"/>
                                <Grid Width="180" Height="10" Background="#3A3A3A">
                                    <Border x:Name="HpBar2" Background="#58D050"
                                    HorizontalAlignment="Left" Width="180"/>
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="Hp2" Text="0/0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== SLOT 3 ===== -->
                <Border x:Name="Slot3" Canvas.Left="20" Canvas.Top="150"
                Width="300" Height="100"
                Background="#F8F8D8"
                BorderBrush="#282828" BorderThickness="4"
                CornerRadius="8" MouseDown="Slot_Click">
                    <Grid Margin="8">
                        <Image x:Name="Img3" Width="70" Height="70"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <StackPanel Margin="90,0,0,0">
                            <TextBlock x:Name="Name3" Text="N/A"/>

                            <Grid Width="180" Height="10" Background="#3A3A3A">
                                <Border x:Name="HpBar3" Background="#58D050"
                                HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <TextBlock x:Name="Hp3" Text="0/0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== SLOT 4 ===== -->
                <Border x:Name="Slot4" Canvas.Left="350" Canvas.Top="180"
                Width="300" Height="100"
                Background="#F8F8D8"
                BorderBrush="#282828" BorderThickness="4"
                CornerRadius="8" MouseDown="Slot_Click">
                    <Grid Margin="8">
                        <Image x:Name="Img4" Width="70" Height="70"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <StackPanel Margin="90,0,0,0">
                            <TextBlock x:Name="Name4" Text="N/A"/>

                            <Grid Width="180" Height="10" Background="#3A3A3A">
                                <Border x:Name="HpBar4" Background="#58D050"
                                HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <TextBlock x:Name="Hp4" Text="0/0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== SLOT 5 ===== -->
                <Border x:Name="Slot5" Canvas.Left="20" Canvas.Top="280"
                Width="300" Height="100"
                Background="#F8F8D8"
                BorderBrush="#282828" BorderThickness="4"
                CornerRadius="8" MouseDown="Slot_Click">
                    <Grid Margin="8">
                        <Image x:Name="Img5" Width="70" Height="70"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <StackPanel Margin="90,0,0,0">
                            <TextBlock x:Name="Name5" Text="N/A"/>

                            <Grid Width="180" Height="10" Background="#3A3A3A">
                                <Border x:Name="HpBar5" Background="#58D050"
                                HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <TextBlock x:Name="Hp5" Text="0/0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== SLOT 6 ===== -->
                <Border x:Name="Slot6" Canvas.Left="350" Canvas.Top="310"
                Width="300" Height="100"
                Background="#F8F8D8"
                BorderBrush="#282828" BorderThickness="4"
                CornerRadius="8" MouseDown="Slot_Click">
                    <Grid Margin="8">
                        <Image x:Name="Img6" Width="70" Height="70"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <StackPanel Margin="90,0,0,0">
                            <TextBlock x:Name="Name6" Text="N/A"/>

                            <Grid Width="180" Height="10" Background="#3A3A3A">
                                <Border x:Name="HpBar6" Background="#58D050"
                                HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <TextBlock x:Name="Hp6" Text="0/0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== TEXTE BAS ===== -->
                <Border Canvas.Left="20" Canvas.Top="420"
                Width="630" Height="80"
                Background="#E8E8E8"
                BorderBrush="#303030"
                BorderThickness="4">
                    <TextBlock Text="Choisis un Pokémon"
                       VerticalAlignment="Center"
                       Margin="15"
                       FontSize="16"/>
                </Border>

                <!-- ===== BOUTON RETOUR ===== -->
                <Button Content="◀ RETOUR"
                Width="180"
                Height="60"
                Canvas.Left="680"
                Canvas.Top="440"
                FontSize="18"
                FontWeight="Bold"
                Background="#2A2A2A"
                Foreground="White"
                BorderBrush="#AAAAAA"
                BorderThickness="3"
                Click="Retour_Click"/>

            </Canvas>
        </Grid>
        <Grid x:Name="StartMenu" Background="Black" Visibility="Visible">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="Choisis ton starter"
                   Foreground="White"
                   FontSize="30"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <!-- Bulbizarre -->
                    <Button Click="ChooseBulbasaur_Click" Margin="10">
                        <StackPanel Height="98" Width="111">
                            <Image Width="100"
       gif:ImageBehavior.AnimatedSource="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/1.gif"
       gif:ImageBehavior.RepeatBehavior="Forever" Height="100"/>
                            <TextBlock Text="Bulbizarre" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Salamèche -->
                    <Button Click="ChooseCharmander_Click" Margin="10">
                        <StackPanel>
                            <Image Width="100"
gif:ImageBehavior.AnimatedSource="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/4.gif"
gif:ImageBehavior.RepeatBehavior="Forever" Height="100"/>
                        </StackPanel>
                    </Button>

                    <!-- Carapuce -->
                    <Button Click="ChooseSquirtle_Click" Margin="10">
                        <StackPanel>
                            <Image Width="100"
gif:ImageBehavior.AnimatedSource="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/7.gif"
gif:ImageBehavior.RepeatBehavior="Forever" Height="100"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </StackPanel>

        </Grid>
        <Viewbox Stretch="Uniform" Visibility="Collapsed" x:Name="GameView">

            <Canvas x:Name="ZoneJeu" Width="800" Height="450">

                <!-- BACKGROUND -->
                <Image Source="/Image/map poke/safaricentral.png"
                       Width="800"
                       Height="450"/>
                <Button x:Name="bttReglage"
        Content="ÉQUIPE"
        Width="63"
        Height="23"
        Click="bttReglage_Click" Canvas.Top="12" Canvas.Left="640" Style="{StaticResource OldPokemonButtonStyle}" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <!-- ZONE BLOQUANTE -->
                <Canvas x:Name="ZoneBloque">

                    <Rectangle Width="60" Height="43" Stroke="Black" Canvas.Left="432" Canvas.Top="284" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="175" Height="15" Stroke="Black" Canvas.Left="306" Canvas.Top="251" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="26" Height="10" Stroke="Black" Canvas.Left="455" Canvas.Top="241" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Rectangle Width="115" Height="16" Stroke="Black" Canvas.Left="195" Canvas.Top="264" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="194" Height="76" Stroke="Black" Canvas.Left="309" Canvas.Top="167" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Rectangle Width="100" Height="190" Stroke="Black" Canvas.Left="614" Canvas.Top="0" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Rectangle Width="251" Height="78" Stroke="Black" Canvas.Left="418" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Rectangle Width="251" Height="23" Stroke="Black" Canvas.Left="127" Canvas.Top="55"/>
                    <Rectangle Width="141" Height="202" Stroke="Black" Canvas.Left="54" Canvas.Top="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Rectangle Width="141" Height="205" Stroke="Black" Canvas.Left="54" Canvas.Top="241"/>
                    <Rectangle Width="260" Height="75" Stroke="Black" Canvas.Left="122" Canvas.Top="377" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="14" Height="112" Stroke="Black" Canvas.Left="356" Canvas.Top="55" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="383" Height="75" Stroke="Black" Canvas.Left="432" Canvas.Top="377" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="125" Height="203" Stroke="Black" Canvas.Left="614" Canvas.Top="219" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Rectangle Width="175" Height="12" Stroke="Black" Canvas.Left="503" Canvas.Top="178" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Rectangle Width="16" Height="77" Stroke="Black" Canvas.Left="378" Canvas.Top="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="12" Height="12" Stroke="Black" Canvas.Left="394" Canvas.Top="339" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Rectangle Width="12" Height="12" Stroke="Black" Canvas.Left="455" Canvas.Top="327" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Rectangle Width="12" Height="12" Stroke="Black" Canvas.Left="493" Canvas.Top="254" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                </Canvas>

                <!-- JOUEUR -->
                <Image x:Name="perso"
                       Source="/Image/sprites garcon/01_front_0.png"
                       Width="14"
                       Height="16"
                       Canvas.Left="398"
                       Canvas.Top="359" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <!-- ZONE HERBE -->
                <Canvas x:Name="ZoneHerbe">

                    <Rectangle Width="12" Height="13" Stroke="Red" Canvas.Left="357" Canvas.Top="350" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                </Canvas>
                <Canvas x:Name="ZoneTP">
                    <Rectangle Width="50" Height="30" Stroke="Blue" Canvas.Left="382" Canvas.Top="378" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Rectangle Width="11" Height="11" Stroke="Blue" Canvas.Left="444" Canvas.Top="318" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Rectangle Width="14" Height="30" Stroke="Blue" Canvas.Left="85" Canvas.Top="210" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Rectangle Width="50" Height="30" Stroke="Blue" Canvas.Left="382" Canvas.Top="-1" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Rectangle Width="22" Height="30" Stroke="Blue" Canvas.Left="695" Canvas.Top="188" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Canvas>
                <Canvas x:Name="Interaction">
                    <Rectangle Width="19" Height="11" Stroke="GreenYellow" Canvas.Left="452" Canvas.Top="338" HorizontalAlignment="Left" VerticalAlignment="Center" Tag="Maison de Raphael"/>
                    <Rectangle Width="19" Height="11" Stroke="GreenYellow" Canvas.Left="391" Canvas.Top="350" HorizontalAlignment="Left" VerticalAlignment="Center" Tag="Bonjour jeune dresseur !"/>
                    <Rectangle Width="19" Height="11" Stroke="GreenYellow" Canvas.Left="490" Canvas.Top="265" HorizontalAlignment="Left" VerticalAlignment="Top" Tag="Trouve Electhor"/>
                </Canvas>
                <Border x:Name="DialogueBox"
        Width="400"
        Height="100"
        Background="Black"
        BorderBrush="White"
        BorderThickness="2"
        Visibility="Hidden"
        VerticalAlignment="Bottom"
        Margin="10">

                    <TextBlock x:Name="DialogueText"
               Foreground="White"
               FontSize="16"
               TextWrapping="Wrap"
               Margin="10"/>
                </Border>

            </Canvas>

        </Viewbox>
        <Grid x:Name="CombatScreen"
      Background="Black"
     Visibility="Collapsed" >

            <Viewbox Stretch="Uniform">


                <Canvas Width="800" Height="500" >

                    <!-- Pokémon ennemi (haut droite) -->
                    <Image x:Name="EnemyPokemon"
                   Width="150" Height="150"
                   Canvas.Left="530" Canvas.Top="50"
                   gif:ImageBehavior.RepeatBehavior="Forever"/>

                    <!-- Pokémon joueur (bas gauche) -->
                    <Image x:Name="PlayerPokemon"
                   Width="150" Height="150"
                   Canvas.Left="150" Canvas.Top="280"
                   gif:ImageBehavior.RepeatBehavior="Forever"/>

                    <!-- Trainer animation lancer -->
                    <Image x:Name="PlayerTrainer"
                   Width="400" Height="307"
                   Canvas.Left="-90" Canvas.Top="250"
                   Source="/Image/Gif/pokeball_throw_back.gif"/>
                    <!-- ══ BOÎTE ENNEMI (haut-gauche) ══ -->
                    <Border Canvas.Left="20" Canvas.Top="18"
              Width="260" Height="72"
              Background="#F8F8D8"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6">
                        <Grid Margin="10,6,10,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Nom + Niveau -->
                            <Grid Grid.Row="0">
                                <TextBlock x:Name="EnemyName" Text="PIKACHU"
                       FontFamily="Courier New" FontWeight="Bold" FontSize="13"
                       HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock x:Name="EnemyGender" Text="♂"
                         Foreground="#5078F0" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="EnemyLevel" Text="Nv.35"
                         FontFamily="Courier New" FontSize="11"
                         Foreground="#505050"/>
                                </StackPanel>
                            </Grid>
                            <!-- Label PV -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,2">
                                <TextBlock Text="PV" FontFamily="Courier New" FontSize="10"
               Foreground="#505050" Margin="0,0,4,0"
               VerticalAlignment="Center"/>
                                <Grid Width="160" Height="10" Background="#3A3A3A">
                                    <Border x:Name="EnemyHpBar"
            Background="#58D050"
            HorizontalAlignment="Left"/>
                                </Grid>

                            </StackPanel>
                            <!-- HP chiffres -->
                            <TextBlock x:Name="EnemyHpText" Grid.Row="2"
                      FontFamily="Courier New" FontSize="10"
                     Foreground="#505050" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- ══ BOÎTE JOUEUR (bas-droite) ══ -->
                    <Border Canvas.Left="510" Canvas.Top="330"
              Width="270" Height="90"
              Background="#F8F8D8"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6">
                        <Grid Margin="10,6,10,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <TextBlock x:Name="PlayerName" Text="PIKACHU"
                       FontFamily="Courier New" FontWeight="Bold" FontSize="13"
                       HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock x:Name="PlayerGender" Text="♀"
                         Foreground="#F05078" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="PlayerLevel" Text="Nv.28"
                         FontFamily="Courier New" FontSize="11"
                                               SnapsToDevicePixels="True"
UseLayoutRounding="True"
                         Foreground="#505050"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,2">
                                <TextBlock Text="PV" FontFamily="Courier New" FontSize="10"
               Foreground="#505050" Margin="0,0,4,0"
               VerticalAlignment="Center"/>
                                <Grid Width="180" Height="10" Background="#3A3A3A">
                                    <Border x:Name="PlayerHp"
            Background="#58D050"
            HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>

                            <!-- EXP -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="EXP" FontFamily="Courier New" FontSize="9"
               Foreground="#5090F0" Margin="0,0,4,0"
               VerticalAlignment="Center"/>
                                <ProgressBar x:Name="PlayerExpBar"
Width="180"
Height="7"
Style="{StaticResource ExpBarStyle}"/>
                                <TextBlock x:Name="PlayerHpText" Grid.Row="2"
Text="36/50" FontFamily="Courier New" FontSize="10"
Foreground="#505050" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══ BOÎTE TEXTE (bas-gauche) ══ -->
                    <Border x:Name="TextBox"
              Canvas.Left="8" Canvas.Top="420"
              Width="392" Height="72"
              Background="#F8F8D8"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6" Padding="12,8">
                        <TextBlock x:Name="CombatText"
                   Text="Un PIKACHU sauvage
est apparu !"
                   FontFamily="Courier New" FontSize="13"
                   Foreground="#181818"
                   TextWrapping="Wrap"/>
                    </Border>
                    <Button x:Name="BtnRetourCombat"
        Width="35"
        Height="28"
        Canvas.Left="475"
        Canvas.Top="392"
        Cursor="Hand"
        Click="BtnRetourCombat_Click" HorizontalAlignment="Left" VerticalAlignment="Center">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#2A2A2A"
                    BorderBrush="#AAAAAA"
                    BorderThickness="2"
                    CornerRadius="4">
                                    <TextBlock Text="◀"
                           Foreground="White"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                    <!-- ══ BOUTONS ACTION (bas-droite) ══ -->
                    <Border Canvas.Left="408" Canvas.Top="420"
              Width="384" Height="72"
              Background="#F8F8D8"
                            Name="ActionPanel"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6">
                        <UniformGrid Rows="2" Columns="2" Margin="6">
                            <Button x:Name="BtnCombat" Content="COMBAT"
                  Background="#E83020" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnCombat_Click"
                 />
                            <Button x:Name="BtnPokemon" Content="POKÉMON"
                  Background="#3878D0" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnPokemon_Click"
                  />
                            <Button x:Name="BtnSac" Content="SAC"
                  Background="#E8C018" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnSac_Click"
                  />
                            <Button x:Name="BtnFuite" Content="FUITE"
                  Background="#38A838" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnFuite_Click"
                 />
                        </UniformGrid>
                    </Border>

                    <!-- ══ PANEL ATTAQUES (masqué par défaut) ══ -->
                    <Border x:Name="AttackPanel"
              Canvas.Left="8" Canvas.Top="420"
              Width="784" Height="72"
              Background="#F8F8D8"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6"
              Visibility="Collapsed">
                        <UniformGrid Rows="2" Columns="2" Margin="6">
                            <Button x:Name="BtnMove1" Content="TONNERRE"
                  Background="#F8C830" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove1_Click" />
                            <Button x:Name="BtnMove2" Content="VIVE-ATTAQUE"
                  Background="#A8A8A8" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove2_Click" />
                            <Button x:Name="BtnMove3" Content="QUEUE DE FER"
                  Background="#A8A8A8" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove3_Click" />
                            <Button x:Name="BtnMove4" Content="RUGISSEMENT"
                  Background="#A8A8A8" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove4_Click" />
                        </UniformGrid>
                    </Border>
                    <Border x:Name="BagPanel"
        Canvas.Left="8"
        Canvas.Top="420"
        Width="784"
        Height="72"
        Background="#F8F8D8"
        BorderBrush="#303030"
        BorderThickness="4"
        CornerRadius="0"
        Visibility="Collapsed">

                        <UniformGrid Rows="2" Columns="3" Margin="4">

                            <!-- Poké Ball -->
                            <Button Click="UsePokeBall_Click" Background="#E03030" Margin="0,0,27,0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/poke-ball.png"
                       Width="24" Height="20" Margin="4"/>
                                    <TextBlock Text="Poké Ball x10"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Super Ball -->
                            <Button Click="UseSuperBall_Click" Background="#3060E0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/great-ball.png"
                       Width="24" Height="20" Margin="4"/>
                                    <TextBlock Text="Super Ball x5"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Hyper Ball -->
                            <Button Click="UseHyperBall_Click" Background="#202020" Margin="25,0,14,-6">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/ultra-ball.png"
                       Width="24" Height="20" Margin="4"/>
                                    <TextBlock Text="Hyper Ball x2"
                           FontFamily="Consolas"
                           Foreground="Yellow"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Potion -->
                            <Button Click="UsePotion_Click" Background="#38A838" Margin="0,0,27,0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/potion.png"
                       Width="24" Height="20"/>
                                    <TextBlock Text="Potion x5"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Super Potion -->
                            <Button Click="UseSuperPotion_Click" Background="#50C878">
                                <StackPanel Orientation="Horizontal">

                <Button Content="◀ RETOUR"
                Width="180"
                Height="60"
                Canvas.Left="680"
                Canvas.Top="440"
                FontSize="18"
                FontWeight="Bold"
                Background="#2A2A2A"
                Foreground="White"
                BorderBrush="#AAAAAA"
                BorderThickness="3"
                Click="Retour_Click"/>

            </Canvas>

                    <!-- Bulbizarre -->
                    <Button Click="ChooseBulbasaur_Click" Margin="10">
                        <StackPanel Height="98" Width="111">
                            <Image Width="100"
       gif:ImageBehavior.AnimatedSource="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/1.gif"
       gif:ImageBehavior.RepeatBehavior="Forever" Height="100"/>
                            <TextBlock Text="Bulbizarre" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Salamèche -->
                    <Button Click="ChooseCharmander_Click" Margin="10">
                        <StackPanel>
                            <Image Width="100"
gif:ImageBehavior.AnimatedSource="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/4.gif"
gif:ImageBehavior.RepeatBehavior="Forever" Height="100"/>
                        </StackPanel>
                    </Button>

                    <!-- Carapuce -->
                    <Button Click="ChooseSquirtle_Click" Margin="10">

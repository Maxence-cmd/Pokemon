<Window x:Class="Pokemon.Views.chasse"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="chasse"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Loaded="Window_Loaded"
        Focusable="True"
        WindowState="Maximized"
        ResizeMode="NoResize">
    <Grid Background="Black">
        <Grid Visibility="Collapsed">
            <wv2:WebView2 x:Name="YouTubePlayer"/>
        </Grid>
        <Grid x:Name="TeamScreen" Background="#A8D0D0" Visibility="Collapsed">

            <Canvas Width="900" Height="550">

                <!-- ===== SLOT 1 ===== -->
                <Border x:Name="Slot1" Canvas.Left="20" Canvas.Top="20"
                Width="300" Height="100"
                Background="#F8F8D8"
                BorderBrush="#282828" BorderThickness="4"
                CornerRadius="8" MouseDown="Slot_Click">
                    <Grid Margin="8">
                        <Image x:Name="Img1" Width="70" Height="70"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <StackPanel Margin="90,0,0,0">
                            <TextBlock x:Name="Name1" Text="N/A" FontSize="16" FontWeight="Bold"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="HP" Margin="0,0,6,0"/>
                                <Grid Width="180" Height="10" Background="#3A3A3A">
                                    <Border x:Name="HpBar1" Background="#58D050"
                                    HorizontalAlignment="Left" Width="180"/>
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="Hp1" Text="0/0" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== SLOT 2 ===== -->
                <Border x:Name="Slot2" Canvas.Left="350" Canvas.Top="50"

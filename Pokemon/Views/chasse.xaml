                            <!-- EXP -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="EXP" FontFamily="Courier New" FontSize="9"
               Foreground="#5090F0" Margin="0,0,4,0"
               VerticalAlignment="Center"/>
                                <ProgressBar x:Name="PlayerExpBar"
Width="180"
Height="7"
Style="{StaticResource ExpBarStyle}"/>
                                <TextBlock x:Name="PlayerHpText" Grid.Row="2"
Text="36/50" FontFamily="Courier New" FontSize="10"
Foreground="#505050" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══ BOÎTE TEXTE (bas-gauche) ══ -->
                    <Border x:Name="TextBox"
              Canvas.Left="8" Canvas.Top="420"
              Width="392" Height="72"
              Background="#F8F8D8"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6" Padding="12,8">
                        <TextBlock x:Name="CombatText"
                   Text="Un PIKACHU sauvage
est apparu !"
                   FontFamily="Courier New" FontSize="13"
                   Foreground="#181818"
                   TextWrapping="Wrap"/>
                    </Border>
                    <Button x:Name="BtnRetourCombat"
        Width="35"
        Height="28"
        Canvas.Left="475"
        Canvas.Top="392"
        Cursor="Hand"
        Click="BtnRetourCombat_Click" HorizontalAlignment="Left" VerticalAlignment="Center">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#2A2A2A"
                    BorderBrush="#AAAAAA"
                    BorderThickness="2"
                    CornerRadius="4">
                                    <TextBlock Text="◀"
                           Foreground="White"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                    <!-- ══ BOUTONS ACTION (bas-droite) ══ -->
                    <Border Canvas.Left="408" Canvas.Top="420"
              Width="384" Height="72"
              Background="#F8F8D8"
                            Name="ActionPanel"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6">
                        <UniformGrid Rows="2" Columns="2" Margin="6">
                            <Button x:Name="BtnCombat" Content="COMBAT"
                  Background="#E83020" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnCombat_Click"
                 />
                            <Button x:Name="BtnPokemon" Content="POKÉMON"
                  Background="#3878D0" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnPokemon_Click"
                  />
                            <Button x:Name="BtnSac" Content="SAC"
                  Background="#E8C018" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnSac_Click"
                  />
                            <Button x:Name="BtnFuite" Content="FUITE"
                  Background="#38A838" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="12"
                  Margin="3" Cursor="Hand" Click="BtnFuite_Click"
                 />
                        </UniformGrid>
                    </Border>

                    <!-- ══ PANEL ATTAQUES (masqué par défaut) ══ -->
                    <Border x:Name="AttackPanel"
              Canvas.Left="8" Canvas.Top="420"
              Width="784" Height="72"
              Background="#F8F8D8"
              BorderBrush="#282828" BorderThickness="3"
              CornerRadius="6"
              Visibility="Collapsed">
                        <UniformGrid Rows="2" Columns="2" Margin="6">
                            <Button x:Name="BtnMove1" Content="TONNERRE"
                  Background="#F8C830" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove1_Click" />
                            <Button x:Name="BtnMove2" Content="VIVE-ATTAQUE"
                  Background="#A8A8A8" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove2_Click" />
                            <Button x:Name="BtnMove3" Content="QUEUE DE FER"
                  Background="#A8A8A8" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove3_Click" />
                            <Button x:Name="BtnMove4" Content="RUGISSEMENT"
                  Background="#A8A8A8" Foreground="White"
                  FontFamily="Courier New" FontWeight="Bold" FontSize="11"
                  Margin="3" Click="BtnMove4_Click" />
                        </UniformGrid>
                    </Border>
                    <Border x:Name="BagPanel"
        Canvas.Left="8"
        Canvas.Top="420"
        Width="784"
        Height="72"
        Background="#F8F8D8"
        BorderBrush="#303030"
        BorderThickness="4"
        CornerRadius="0"
        Visibility="Collapsed">

                        <UniformGrid Rows="2" Columns="3" Margin="4">

                            <!-- Poké Ball -->
                            <Button x:Name="BtnPokeBall" Click="UsePokeBall_Click" Background="#E03030" Margin="0,0,27,0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/poke-ball.png"
                       Width="24" Height="20" Margin="4"/>
                                    <TextBlock Text="Poké Ball x10"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Super Ball -->
                            <Button x:Name="BtnSuperBall" Click="UseSuperBall_Click" Background="#3060E0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/great-ball.png"
                       Width="24" Height="20" Margin="4"/>
                                    <TextBlock Text="Super Ball x5"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Hyper Ball -->
                            <Button x:Name="BtnHyperBall" Click="UseHyperBall_Click" Background="#202020" Margin="25,0,14,-6">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/ultra-ball.png"
                       Width="24" Height="20" Margin="4"/>
                                    <TextBlock Text="Hyper Ball x2"
                           FontFamily="Consolas"
                           Foreground="Yellow"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Potion -->
                            <Button x:Name="BtnPotion" Click="UsePotion_Click" Background="#38A838" Margin="0,0,27,0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/potion.png"
                       Width="24" Height="20"/>
                                    <TextBlock Text="Potion x5"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Super Potion -->
                            <Button x:Name="BtnSuperPotion" Click="UseSuperPotion_Click" Background="#50C878">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/super-potion.png"
                       Width="24" Height="24"/>
                                    <TextBlock Text="Super Potion x3"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Hyper Potion -->
                            <Button x:Name="BtnHyperPotion" Click="UseHyperPotion_Click" Background="#A855F7" Margin="25,0,14,0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/hyper-potion.png"
                       Width="24" Height="24"/>
                                    <TextBlock Text="Hyper Potion x1"
                           FontFamily="Consolas"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </UniformGrid>
                    </Border>

                </Canvas>
            </Viewbox>
        </Grid>
    </Grid>

</Window>
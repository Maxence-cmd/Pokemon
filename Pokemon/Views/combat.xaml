<Window x:Class="Pokemon.Views.combat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pokemon"
        mc:Ignorable="d"
        Title="combat" Height="450" Width="800">
    <Grid>
        <Grid x:Name="CombatScreenRoot">
            <Grid.Background>
                <ImageBrush ImageSource="/Image/fondpoke.png"
                    Stretch="UniformToFill"/>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Zone des Pokémon -->
            <Grid x:Name="PokemonBattleArea">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Pokémon Joueur -->
                <StackPanel x:Name="PlayerPokemonContainer"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    >

                    <Image x:Name="PlayerPokemonSprite"
                   Source="https://raw.githubusercontent.com/Yarkis01/TyraDex/images/sprites/98/regular.png"
                   Width="200"
                   Height="200">
                        <Image.RenderTransform>
                            <TranslateTransform x:Name="PlayerShakeTransform"/>
                        </Image.RenderTransform>
                    </Image>

                    <StackPanel x:Name="PlayerPokemonStatus"
                        Width="220">

                        <TextBlock x:Name="PlayerPokemonName"
                           Text="Lokhlass"
                           FontSize="18"
                           FontWeight="Bold"/>
                        <ProgressBar Height="8"
                                     x:Name="PlayerPokemonHPBar"
             Background="#1F2937"
             BorderThickness="0"
             Value="50"
             Maximum="100">

    <ProgressBar.Foreground>
        <SolidColorBrush Color="#22C55E"/>
    </ProgressBar.Foreground>
</ProgressBar>

                       

                        <TextBlock x:Name="PlayerPokemonHPText"
                           Text="260 / 260"
                           HorizontalAlignment="Right"/>
                    </StackPanel>

                </StackPanel>


                <!-- Pokémon Ennemi -->
                <StackPanel x:Name="EnemyPokemonContainer"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    >

                    <Image x:Name="EnemyPokemonSprite"
                   Source="https://raw.githubusercontent.com/Yarkis01/TyraDex/images/sprites/67/shiny.png"
                   Width="200"
                   Height="200">
                        <Image.RenderTransform>
                            <TranslateTransform x:Name="EnemyShakeTransform"/>
                        </Image.RenderTransform>
                    </Image>

                    <StackPanel x:Name="EnemyPokemonStatus"
                        Width="220">

                        <TextBlock x:Name="EnemyPokemonName"
                           Text="Brutapode"
                           FontSize="18"
                           FontWeight="Bold"/>
                        <ProgressBar Height="8"
                                     x:Name="EnemyPokemonHPBar"
             Background="#1F2937"
             BorderThickness="0"
             Value="50"
             Maximum="100">

                            <ProgressBar.Foreground>
                                <SolidColorBrush Color="#22C55E"/>
                            </ProgressBar.Foreground>
                        </ProgressBar>

                        

                        <TextBlock x:Name="EnemyPokemonHPText"
                           Text="100 / 100"
                           HorizontalAlignment="Right"/>
                    </StackPanel>

                </StackPanel>

            </Grid>


            <!-- Menu Combat -->
            <Grid Grid.Row="1">

                <!-- MENU DROITE -->
                <StackPanel HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,30,0">

                    <!-- ATTAQUE -->
                    <Button x:Name="AttackButton"
                Content="⚔ ATTAQUE"
                Width="200"
                Height="50"
                Margin="0,0,0,10"
                Foreground="White"
                FontWeight="Bold"
                FontSize="14"
                Cursor="Hand"
                Click="AttackButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                            CornerRadius="8"
                            Background="#1F2937"
                            BorderBrush="#374151"
                            BorderThickness="1"
                            Padding="10">

                                    <Grid>
                                        <TextBlock Text="{TemplateBinding Content}"
                                       VerticalAlignment="Center"/>

                                        <!-- Ligne bleue -->
                                        <Border x:Name="highlight"
                                    Height="3"
                                    Background="#3B82F6"
                                    VerticalAlignment="Bottom"
                                    Opacity="0"/>
                                    </Grid>
                                </Border>

                                <ControlTemplate.Triggers>

                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                    Property="Background"
                                    Value="#111827"/>
                                        <Setter TargetName="highlight"
                                    Property="Opacity"
                                    Value="1"/>
                                    </Trigger>

                                    <!-- Click -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                    Property="Background"
                                    Value="#020617"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- POKEMON -->
                    <Button x:Name="PokemonButton"
                Content="🐾 POKÉMON"
                Width="200"
                Height="50"
                Foreground="White"
                FontWeight="Bold"
                FontSize="14"
                Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                            CornerRadius="8"
                            Background="#1F2937"
                            BorderBrush="#374151"
                            BorderThickness="1"
                            Padding="10">

                                    <Grid>
                                        <TextBlock Text="{TemplateBinding Content}"
                                       VerticalAlignment="Center"/>

                                        <Border x:Name="highlight"
                                    Height="3"
                                    Background="#3B82F6"
                                    VerticalAlignment="Bottom"
                                    Opacity="0"/>
                                    </Grid>
                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                    Property="Background"
                                    Value="#111827"/>
                                        <Setter TargetName="highlight"
                                    Property="Opacity"
                                    Value="1"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                    Property="Background"
                                    Value="#020617"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

            </Grid>

        </Grid>
    </Grid>
</Window>

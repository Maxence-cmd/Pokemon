<UserControl x:Class="Pokemon.View.combat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pokemon.View"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="900"  Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pokémon Style Resources -->
        <Grid.Resources>

            <Style TargetType="GroupBox">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="BorderBrush" Value="#2A75BB"/>
                <Setter Property="BorderThickness" Value="3"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Margin" Value="10"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Background" Value="#FFCB05"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="BorderBrush" Value="#2A75BB"/>
                <Setter Property="BorderThickness" Value="3"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>

        </Grid.Resources>

        <!-- Title -->
        <Border Grid.Row="0"
                Background="#2A75BB"
                CornerRadius="10"
                Padding="10"
                Margin="0,0,0,20">

            <TextBlock Text="Combat Pokémon"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#FFCB05"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Player 1 -->
            <GroupBox Header="Joueur 1" Grid.Column="0">

                <StackPanel HorizontalAlignment="Center">

                    <TextBlock x:Name="Pokemon1Name"
                               Text="Nom du Pokémon"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,5"/>

                    <Border Background="White"
                            BorderBrush="#2A75BB"
                            BorderThickness="2"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,10">

                        <Image x:Name="Pokemon1Image"
                               Width="150"
                               Height="150"
                               Stretch="Uniform"/>
                    </Border>

                    <StackPanel Margin="10">

                        <TextBlock Text="HP:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon1HP" Text="0" Margin="0,0,0,5"/>

                        <TextBlock Text="Attack:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon1Attack" Text="0" Margin="0,0,0,5"/>

                        <TextBlock Text="Defense:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon1Defense" Text="0" Margin="0,0,0,5"/>

                        <TextBlock Text="Speed:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon1Speed" Text="0"/>

                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <!-- Center Button -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="20">

                <Button x:Name="RandomPokemonButton"
                        Content="Choisir un Pokémon aléatoire"
                        HorizontalAlignment="Center" Click="RandomPokemonButton_Click"/>

            </StackPanel>

            <!-- Player 2 -->
            <GroupBox Header="Joueur 2" Grid.Column="2">

                <StackPanel HorizontalAlignment="Center">

                    <TextBlock x:Name="Pokemon2Name"
                               Text="Nom du Pokémon"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,5"/>

                    <Border Background="White"
                            BorderBrush="#2A75BB"
                            BorderThickness="2"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,10">

                        <Image x:Name="Pokemon2Image"
                               Width="150"
                               Height="150"
                               Stretch="Uniform"/>
                    </Border>

                    <StackPanel Margin="10">

                        <TextBlock Text="HP:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon2HP" Text="0" Margin="0,0,0,5"/>

                        <TextBlock Text="Attack:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon2Attack" Text="0" Margin="0,0,0,5"/>

                        <TextBlock Text="Defense:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon2Defense" Text="0" Margin="0,0,0,5"/>

                        <TextBlock Text="Speed:" FontWeight="Bold"/>
                        <TextBlock x:Name="Pokemon2Speed" Text="0"/>

                    </StackPanel>

                </StackPanel>
            </GroupBox>

        </Grid>

        <!-- Result -->
        <Border Grid.Row="2"
                Background="#2A75BB"
                CornerRadius="10"
                Padding="12"
                Margin="0,20,0,0">

            <TextBlock x:Name="ResultText"
                       Text="Résultat du combat"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

        </Border>

    </Grid>
</UserControl>
